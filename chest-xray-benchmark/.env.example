# =============================================================================
# Chest X-ray Benchmark — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your paths

# ── Dataset Paths ────────────────────────────────────────────────────────────
DATA_ROOT=./data
COVID_QU_EX_PATH=./data/raw/covid
CHEXPERT_PATH=./data/raw/chexpert
NIH_CHESTXRAY14_PATH=./data/raw/nih
VINDR_CXR_PATH=./data/raw/vindr
SHENZHEN_TB_PATH=./data/raw/shenzhen_tb
LIDC_IDRI_PATH=./data/raw/lidc_idri

# ── Training ──────────────────────────────────────────────────────────────────
DEVICE=cuda
NUM_WORKERS=4
SEED=42

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MODEL_CHECKPOINT_DIR=./outputs/checkpoints
